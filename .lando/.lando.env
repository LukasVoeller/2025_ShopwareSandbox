# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_SESSION=10
REDIS_LOCK=6
REDIS_CACHE=0
REDIS_MESSAGE_QUEUE=1
REDIS_HIGH_PRIORITY=2

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SOCKET=redis://${REDIS_HOST}:${REDIS_PORT}
REDIS_MESSAGE_QUEUE_HIGH_PRIORITY=${REDIS_SOCKET}/${REDIS_HIGH_PRIORITY}

